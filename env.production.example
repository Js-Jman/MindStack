# App
NODE_ENV=production
NEXTAUTH_URL=http://<VM_PUBLIC_IP_OR_DOMAIN>
NEXTAUTH_SECRET=replace_with_strong_random_secret

# MySQL Container
MYSQL_ROOT_PASSWORD=replace_with_strong_root_password
MYSQL_DATABASE=mindstack
MYSQL_USER=mindstack_user
MYSQL_PASSWORD=replace_with_strong_app_password

# Static private IP of the MySQL container on Docker bridge network
MYSQL_PRIVATE_IP=172.30.0.10

# Prisma / App DB connection string used by Next.js backend
DATABASE_URL=mysql://mindstack_user:replace_with_strong_app_password@172.30.0.10:3306/mindstack
